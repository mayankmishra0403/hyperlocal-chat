PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hyperlocal_chat
DB_USER=chat_user
DB_PASS=chat_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-here

# SMS Provider: "console" (logs OTP) or "textbee" (sends via phone)
SMS_PROVIDER=console

# TextBee SMS Gateway (only needed when SMS_PROVIDER=textbee)
TEXTBEE_API_KEY=your-textbee-api-key
TEXTBEE_DEVICE_ID=your-textbee-device-id
TEXTBEE_API_BASE=https://api.textbee.dev

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# Group settings
MAX_GROUP_DURATION_HOURS=2
MAX_GROUP_MEMBERS=50
PROXIMITY_RADIUS_METERS=10000
LOCATION_GRACE_PERIOD_SECONDS=120
